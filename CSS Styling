.checklist-container {
  max-width: 600px;
  margin: 20px auto;
  font-family: Arial, sans-serif;
}
#checklist-form {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}
#item-input {
  flex: 1;
  padding: 8px;
  font-size: 16px;
}
.checklist-table {
  width: 100%;
  border-collapse: collapse;
}
.checklist-table th, .checklist-table td {
  border-bottom: 1px solid #ddd;
  padding: 12px;
  text-align: left;
}
.completed {
  text-decoration: line-through;
  color: #888;
}
.btn-add { background: #28a745; color: white; border: none; padding: 8px 16px; cursor: pointer; }
.btn-edit { background: #ffc107; color: black; border: none; padding: 4px 8px; margin-right: 5px; cursor: pointer; }
.btn-delete { background: #dc3545; color: white; border: none; padding: 4px 8px; cursor: pointer; }
