<div class="checklist-container">
  <h2>Trip Packing Checklist</h2>
  
  <form id="checklist-form">
    <input type="text" id="item-input" placeholder="e.g., Bring camera charger" required />
    <button type="submit" class="btn-add">Add Item</button>
  </form>

  <table class="checklist-table">
    <thead>
      <tr>
        <th width="10%">Status</th>
        <th width="60%">Item Description</th>
        <th width="30%">Actions</th>
      </tr>
    </thead>
    <tbody id="checklist-tbody">
      </tbody>
  </table>
</div>
