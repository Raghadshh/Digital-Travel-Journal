// Sample initial data (Replace with API fetch call later)
let checklist = [
  { id: 1, title: "Renew Passport", is_completed: true },
  { id: 2, title: "Book flight tickets", is_completed: false }
];

const tbody = document.getElementById('checklist-tbody');
const form = document.getElementById('checklist-form');
const input = document.getElementById('item-input');

// 1. READ: Render the table rows
function renderChecklist() {
  tbody.innerHTML = '';
  
  checklist.forEach(item => {
    const tr = document.createElement('tr');
    
    tr.innerHTML = `
      <td>
        <input type="checkbox" ${item.is_completed ? 'checked' : ''} onclick="toggleComplete(${item.id})">
      </td>
      <td class="${item.is_completed ? 'completed' : ''}" id="text-${item.id}">
        ${item.title}
      </td>
      <td>
        <button class="btn-edit" onclick="editItem(${item.id})">Edit</button>
        <button class="btn-delete" onclick="deleteItem(${item.id})">Delete</button>
      </td>
    `;
    tbody.appendChild(tr);
  });
}

// 2. CREATE: Add a new item
form.addEventListener('submit', (e) => {
  e.preventDefault();
  const newItem = {
    id: Date.now(), // Temporary unique ID
    title: input.value,
    is_completed: false
  };
  checklist.push(newItem);
  input.value = '';
  renderChecklist();
});

// 3. UPDATE: Toggle checkbox complete status
function toggleComplete(id) {
  const item = checklist.find(i => i.id === id);
  if (item) {
    item.is_completed = !item.is_completed;
    renderChecklist();
  }
}

// 4. UPDATE: Edit item text inline
function editItem(id) {
  const item = checklist.find(i => i.id === id);
  const newTitle = prompt("Edit checklist item:", item.title);
  if (newTitle !== null && newTitle.trim() !== "") {
    item.title = newTitle.trim();
    renderChecklist();
  }
}

// 5. DELETE: Remove an item
function deleteItem(id) {
  if (confirm("Are you sure you want to delete this item?")) {
    checklist = checklist.filter(i => i.id !== id);
    renderChecklist();
  }
}

// Initial Render on Page Load
renderChecklist();
